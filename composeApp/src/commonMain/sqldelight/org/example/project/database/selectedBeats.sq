CREATE TABLE selectedBeats (
    id INTEGER PRIMARY KEY NOT NULL,
    name TEXT NOT NULL,
    instrument TEXT NOT NULL,
    FOREIGN KEY (id) REFERENCES beats (id) ON DELETE CASCADE
);

insertBeat:
INSERT INTO selectedBeats(name, instrument) VALUES (?, ?);

showSelectedBeats:
SELECT * FROM selectedBeats;

markAsSelected:
INSERT OR REPLACE INTO selectedBeats(id, name, instrument)
SELECT id, name, instrument FROM beats WHERE id = ?;